{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",

  "width": 800,
  "height": 420,

  "title": {
    "text": "Population Distribution Across Australian States",
    "subtitle": "Darker states have larger populations",
    "fontSize": 22,
    "subtitleFontSize": 14,
    "anchor": "start"
  },

  "projection": {
    "type": "mercator"
  },

  "layer": [
    {
      "data": {
        "url": "../data/australia.json",
        "format": {
          "type": "topojson",
          "feature": "australia"
        }
      },

      "transform": [
        {
          "lookup": "properties.name",
          "from": {
            "data": {
              "url": "../data/state_data.csv"
            },
            "key": "State",
            "fields": ["Population"]
          }
        },
        {
          "calculate": "toNumber(replace(datum.Population, /,/g, ''))",
          "as": "PopulationClean"
        },
        {
          "filter": "isValid(datum.PopulationClean)"
        }
      ],

      "mark": {
        "type": "geoshape",
        "stroke": "white",
        "strokeWidth": 1
      },

      "encoding": {
        "color": {
          "field": "PopulationClean",
          "type": "quantitative",
          "title": "Population",
          "scale": {
            "scheme": "blues"
          },
          "legend": {
            "format": ".2s"
          }
        },

        "tooltip": [
          {
            "field": "properties.name",
            "type": "nominal",
            "title": "State"
          },
          {
            "field": "PopulationClean",
            "type": "quantitative",
            "title": "Population",
            "format": ","
          }
        ]
      }
    },

    {
      "data": {
        "values": [
          { "state": "Western Australia", "abbr": "WA", "lon": 121.0, "lat": -25.5 },
          { "state": "Northern Territory", "abbr": "NT", "lon": 133.5, "lat": -19.5 },
          { "state": "South Australia", "abbr": "SA", "lon": 135.5, "lat": -30.0 },
          { "state": "Queensland", "abbr": "QLD", "lon": 144.5, "lat": -22.5 },
          { "state": "New South Wales", "abbr": "NSW", "lon": 147.0, "lat": -32.5 },
          { "state": "Victoria", "abbr": "VIC", "lon": 144.5, "lat": -37.0 },
          { "state": "Tasmania", "abbr": "TAS", "lon": 146.5, "lat": -42.0 },
          { "state": "Australian Capital Territory", "abbr": "ACT", "lon": 149.0, "lat": -35.4 }
        ]
      },

      "mark": {
        "type": "text",
        "fontSize": 14,
        "fontWeight": "bold",
        "color": "#1f2933",
        "stroke": "white",
        "strokeWidth": 0.5
      },

      "encoding": {
        "longitude": {
          "field": "lon",
          "type": "quantitative"
        },
        "latitude": {
          "field": "lat",
          "type": "quantitative"
        },
        "text": {
          "field": "abbr",
          "type": "nominal"
        },
        "tooltip": [
          {
            "field": "state",
            "type": "nominal",
            "title": "State"
          }
        ]
      }
    }
  ],

  "config": {
    "background": "#ffffff",
    "view": {
      "stroke": null
    }
  }
}
